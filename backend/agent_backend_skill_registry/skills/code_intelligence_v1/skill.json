{
  "skill_id": "code_intelligence_v1",
  "version": "0.2.0",
  "name": "Code intelligence",
  "description": "Build a code map, repo context summary, or dependency graph for a target repository using static analysis. Read-only. Returns structured data bounded for LLM context.",
  "triggers": [
    "code map",
    "repo context",
    "codebase summary",
    "file inventory",
    "code structure analysis",
    "summarize codebase"
  ],
  "capabilities": [
    "code_map",
    "repo_context_summary",
    "file_inventory",
    "language_breakdown"
  ],
  "inputs_schema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "target_repo": { "type": "string" },
      "mode": { "type": "string", "enum": ["code_map", "dependency_graph", "repo_context", "mermaid"] },
      "focus_paths": { "type": "array", "items": { "type": "string" } },
      "max_files": { "type": "integer" },
      "max_chars": { "type": "integer" }
    },
    "required": ["target_repo", "mode"]
  },
  "outputs_schema": {
    "type": "object",
    "additionalProperties": true,
    "properties": {
      "ok": { "type": "boolean" },
      "mode": { "type": "string" },
      "truncated": { "type": "boolean" }
    },
    "required": ["ok", "mode"]
  },
  "project_scope": ["*"],
  "memory_scope": "project",
  "tool_entrypoints": [
    {
      "entrypoint_type": "instruction_only",
      "target": "SKILL.md"
    }
  ],
  "allowed_tools": [
    "mcp_code_intelligence",
    "mcp_get_active_partition"
  ],
  "risk_tier": "T1",
  "approval_requirements": {
    "requires_user_approval": false,
    "requires_diff_approval": false
  },
  "test_commands": [],
  "rollback_strategy": "none",
  "artifacts_produced": ["code_map", "repo_context", "language_summary"]
}
