{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["pipeline_id", "version", "name", "steps"],
  "additionalProperties": false,
  "properties": {
    "pipeline_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "version": { "type": "string" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "max_steps": { "type": "integer", "minimum": 1, "maximum": 50 },
    "variables": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["step_id", "tool_name", "description"],
        "additionalProperties": false,
        "properties": {
          "step_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "tool_name": { "type": "string", "pattern": "^mcp_[a-z_]+$" },
          "description": { "type": "string", "minLength": 1 },
          "args": { "type": "object" },
          "outputs": {
            "type": "object",
            "additionalProperties": {
              "type": "string",
              "pattern": "^(artifacts|result|error|status|summary)\\.[A-Za-z_][A-Za-z0-9_]*$"
            }
          },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" }
          },
          "required_outputs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "negative_constraints": {
            "type": "array",
            "items": { "type": "string" }
          },
          "depth": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
